# ─── Required ────────────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Sheets API service account (used for all Neo sheet reads/writes)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Neo Google Sheet ID (hosts ALL tabs: Tenant Info, property-info-clean,
# Turnover Inspections, Property Info History). Read by sync-from-neo.mjs +
# the get-property-info / update-property-info Netlify functions.
SHEET_ID_PROPERTY_INFO=your-neo-sheet-id

# ─── Optional ────────────────────────────────────────────────────────────────

# Change-summary email (sync-from-neo.mjs sends a digest after each sync if
# there were resident changes). Skipped silently if any of these are missing.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-app-password
MEETING_EMAIL_TO=team@yourdomain.com

# GitHub PAT with `actions:write` scope. Used by netlify/functions/trigger-sync
# to dispatch the sync-neo.yml workflow from the dashboard's Sync button.
# Set this in Netlify env vars, NOT in your local .env.
# GH_DISPATCH_TOKEN=ghp_xxx
