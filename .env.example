# ============================================================
# Mills Rentals Dashboard — Environment Variables
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.
# ============================================================

# ─── Supabase (Phase 2+) ────────────────────────────────────
# Get these from: Supabase dashboard → Settings → API
#
# SUPABASE_SERVICE_KEY is the service_role key — NEVER expose to the browser.
# Only used in Netlify Functions. It bypasses RLS and can read/write everything.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── CSV Sync authentication ────────────────────────────────
# Random secret included by Amanda's Apple Shortcut when POSTing CSV data.
# Generate with: openssl rand -hex 32
# Add this same value to the Shortcut request header as: x-sync-token
CSV_SYNC_TOKEN=replace-with-a-strong-random-secret

# ─── Google Sheets API (legacy fallback) ────────────────────
# Used as a fallback if Supabase is unavailable.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
SHEET_ID=1AEZoTw-NeAz6ReOBOyN-9dzzcV5aIb4eKHS60qMOhSw
SHEET_TAB_RENEWALS=Sheet1
SHEET_TAB_PROPERTIES=Sheet2
