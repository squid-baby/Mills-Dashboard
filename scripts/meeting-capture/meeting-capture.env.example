# Copy this file to meeting-capture.env (same dir) and fill in real values.
# Sourced by record-meeting.sh and process-meeting.mjs.

# ── Audio device ─────────────────────────────────────────────────────────────
# Name of the macOS audio input device (run `ffmpeg -f avfoundation -list_devices true -i ""` to list)
ANKER_DEVICE="PowerConf S3"

# ── Recording status page (cloud) ────────────────────────────────────────────
# Netlify-hosted endpoint that backs https://mills-dashboard.netlify.app/recording.html
# Both vars must be set for the page to update; if either is missing the curl
# call is skipped silently (recording still works).
RECORDING_STATUS_URL="https://mills-dashboard.netlify.app/api/recording-status"

# Shared secret — must exactly match the RECORDING_SECRET env var in Netlify.
# Generate with: openssl rand -hex 16
RECORDING_SECRET=""

# ── Email (process-meeting.mjs sends meeting summaries) ──────────────────────
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
MEETING_EMAIL_TO=""

# ── Anthropic (transcription cleanup / summarization) ────────────────────────
ANTHROPIC_API_KEY=""
